# Copy to .env.local for local dev, or set when building for production.
# Local dev: MUST point at Nest (port 3000), not Vite (5173), or uploads return "Cannot POST"
# VITE_API_URL=http://localhost:3000
# Production build: VITE_API_URL=https://api.sembuzz.com npm run build
#
# If VITE_API_URL is localhost but you view production-posted news (files on VPS), set:
# VITE_ASSET_BASE_URL=https://api.sembuzz.com
# so <img> URLs under /uploads load from production while JSON still hits your local API.

# Backend API URL (no trailing slash). Do not use "/" or http://localhost:5173
VITE_API_URL=https://api.sembuzz.com
