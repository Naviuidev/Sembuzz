# Copy to .env and fill in values. Never commit .env.

# Database (Hostinger MySQL example)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://u500831783_Sembuzzz:YOUR_DB_PASSWORD@localhost:3306/u500831783_Sembuzzz"

# Server
PORT=3000
NODE_ENV=production

# JWT (use a long random string in production)
JWT_SECRET="your-secret-key-change-in-production"

# CORS: comma-separated allowed origins (frontend + www)
CORS_ORIGIN="https://sembuzz.com,https://www.sembuzz.com"

# Base URL of this API (for emails and links)
API_URL="https://api.sembuzz.com"

# Frontend URL (for email links)
FRONTEND_URL="https://sembuzz.com"

# SMTP (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=admin@sembuzz.com
SMTP_PASS=your-smtp-password
SMTP_FROM=admin@sembuzz.com

# Optional
# SUPPORT_EMAIL=support@sembuzz.com
